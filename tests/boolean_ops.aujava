public class Main {
    public static void main(String[] args) {
        int a = 5;
        int b = 10;

        boolean b1 = a < b;                   // true
        boolean b2 = a >= b;                  // false
        boolean b3 = b1 && !b2;               // true && true = true
        boolean b4 = b1 || b2;                // true || false = true
        boolean b5 = (a == 5) && (b != 10);   // true && false = false
        boolean b6 = !b5;                     // true
        boolean b7 = (a <= 5) && (b >= 10);   // true && true = true

        int result = 0;
        if (b3) {
            result = result + 1;
        }
        if (b4) {
            result = result + 2;
        }
        if (b6) {
            result = result + 4;
        }
        if (b2) {
            result = result + 8;
        }
        if (b7) {
            result = result + 16;
        }
        System.out.println(result);
    }
}
