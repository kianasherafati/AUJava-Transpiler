class A {
    int a;

    int test(int d) {
        return a * d;
    }
}

class B extends A {
    int test(int d) {
        return a + d;
    }
}

public class Main {
    public static void main(String[] args) {
        A obj = new B();
        obj.a = 5;
        int result = obj.test(3);
        System.out.println(result);
    }
}
